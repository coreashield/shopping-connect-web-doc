---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { categoryList } from '../lib/categories';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recent = posts.slice(0, 12);
const cats = categoryList(posts);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.intro {
				margin-bottom: 2rem;
			}
			.intro h1 {
				margin: 0 0 0.5rem 0;
			}
			.intro p {
				color: rgb(var(--gray));
				margin: 0;
			}
			.recent-head {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				margin-bottom: 1rem;
			}
			.recent-head a {
				font-size: 0.9rem;
			}
			.categories {
				margin-bottom: 2.5rem;
			}
			.categories h2 {
				margin-bottom: 1rem;
			}
			ul.cat-chips {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
			}
			ul.cat-chips li a {
				display: inline-block;
				padding: 0.5rem 0.9rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				text-decoration: none;
				color: rgb(var(--black));
				transition: 0.2s ease;
			}
			ul.cat-chips li a:hover {
				border-color: rgb(var(--accent));
				color: rgb(var(--accent));
			}
			ul.cat-chips .count {
				color: rgb(var(--gray));
				font-size: 0.85em;
			}
			ul.posts {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			ul.posts li {
				padding: 0.6rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			ul.posts li a {
				display: flex;
				justify-content: space-between;
				gap: 1rem;
				text-decoration: none;
			}
			ul.posts .title {
				color: rgb(var(--black));
			}
			ul.posts .date {
				color: rgb(var(--gray));
				white-space: nowrap;
			}
			ul.posts li a:hover .title {
				color: rgb(var(--accent));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<h1>{SITE_TITLE}</h1>
				<p>{SITE_DESCRIPTION}</p>
			</section>
			<section class="categories">
				<div class="recent-head">
					<h2>카테고리</h2>
					<a href="/category/">전체 보기 →</a>
				</div>
				<ul class="cat-chips">
					{
						cats.map((c) => (
							<li>
								<a href={`/category/${c.slug}/`}>
									{c.name} <span class="count">{c.count}</span>
								</a>
							</li>
						))
					}
				</ul>
			</section>
			<section>
				<div class="recent-head">
					<h2>최근 글</h2>
					<a href="/blog/">전체 글 보기 →</a>
				</div>
				<ul class="posts">
					{
						recent.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<span class="title">{post.data.title}</span>
									<span class="date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
