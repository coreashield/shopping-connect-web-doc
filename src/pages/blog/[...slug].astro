---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { topCategory } from '../../lib/categories';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

// 관련 글 (토픽 클러스터 — 같은 최상위 카테고리 우선, 부족하면 최신글로 채움)
const all = (await getCollection('blog')).filter((p) => p.id !== post.id);
const byDate = (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
	b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
const top = topCategory(post.data.category);
const sameCat = all.filter((p) => topCategory(p.data.category) === top).sort(byDate);
const rest = all.filter((p) => !sameCat.includes(p)).sort(byDate);
const relatedPosts = [...sameCat, ...rest].slice(0, 6);
---

<BlogPost {...post.data} relatedPosts={relatedPosts}>
	<Content />
</BlogPost>
