---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import SeoSchema from '../components/SeoSchema.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { categorySlug, topCategory } from '../lib/categories';

type Props = CollectionEntry<'blog'>['data'] & {
	relatedPosts?: CollectionEntry<'blog'>[];
};

const { title, description, pubDate, updatedDate, heroImage, category, relatedPosts = [],
	affiliateUrl, productStore, rating } = Astro.props;
const catName = topCategory(category);
const catSlug = categorySlug(category);
const rawImg = typeof heroImage === 'string' ? heroImage : heroImage?.src;
const imageUrl = rawImg ? new URL(rawImg, Astro.site).href : undefined;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} type="article" />
		<SeoSchema
			title={title}
			description={description}
			pubDate={pubDate}
			updatedDate={updatedDate}
			catName={catName}
			catSlug={catSlug}
			imageUrl={imageUrl}
		/>
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.cat-link {
				color: rgb(var(--accent));
				text-decoration: none;
				font-weight: 600;
			}
			.cat-link:hover {
				text-decoration: underline;
			}
			.dot {
				margin: 0 0.4em;
				color: rgb(var(--gray-light));
			}
			.last-updated-on {
				font-style: italic;
			}
			.breadcrumb {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				padding-top: 0.5em;
			}
			.breadcrumb a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumb a:hover {
				color: rgb(var(--accent));
			}
			.buy-cta {
				text-align: center;
				margin: 1.6em auto;
			}
			.buy-cta-top {
				margin: 1.2em auto 2em;
			}
			.buy-cta-bottom {
				margin: 2.5em auto 1em;
			}
			.buy-btn {
				display: block;
				width: 100%;
				box-sizing: border-box;
				background: #03c75a;
				color: #fff;
				font-size: 1.15rem;
				font-weight: 700;
				text-decoration: none;
				padding: 0.95em 1.2em;
				border-radius: 12px;
				box-shadow: 0 4px 14px rgba(3, 199, 90, 0.35);
				transition: transform 0.1s ease, box-shadow 0.1s ease;
			}
			.buy-btn:hover {
				transform: translateY(-2px);
				box-shadow: 0 6px 18px rgba(3, 199, 90, 0.45);
				text-decoration: none;
				color: #fff;
			}
			.buy-meta {
				margin: 0 0 0.6em 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			.buy-meta span {
				margin: 0 0.45em;
			}
			.buy-rating {
				color: #f5a623;
				font-weight: 700;
			}
			.buy-note {
				margin: 0.55em 0 0 0;
				font-size: 0.8rem;
				color: rgb(var(--gray));
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && (typeof heroImage === 'string'
						? <img src={heroImage} alt={title} loading="eager" />
						: <Image width={1020} height={510} src={heroImage} alt={title} />)}
				</div>
				<div class="prose">
					<nav class="breadcrumb" aria-label="breadcrumb">
						<a href="/">홈</a>
						<span class="dot">›</span>
						<a href={`/category/${catSlug}/`}>{catName}</a>
					</nav>
					<div class="title">
						<div class="date">
							<a class="cat-link" href={`/category/${catSlug}/`}>{catName}</a>
							<span class="dot">·</span>
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					{affiliateUrl && (
						<div class="buy-cta buy-cta-top">
							{(productStore || rating) && (
								<p class="buy-meta">
									{productStore && <span>🏪 {productStore}</span>}
									{rating ? <span class="buy-rating">★ {rating.toFixed(1)}</span> : null}
								</p>
							)}
							<a class="buy-btn" href={affiliateUrl} target="_blank" rel="nofollow sponsored noopener">
								🛒 네이버 최저가 확인하고 구매하기
							</a>
							<p class="buy-note">가격·재고는 판매처에서 실시간 확인하세요</p>
						</div>
					)}
					<slot />
					{affiliateUrl && (
						<div class="buy-cta buy-cta-bottom">
							<a class="buy-btn" href={affiliateUrl} target="_blank" rel="nofollow sponsored noopener">
								🛒 네이버에서 지금 구매하기
							</a>
						</div>
					)}
					{relatedPosts.length > 0 && (
						<aside class="related">
							<h2>함께 보면 좋은 글</h2>
							<ul>
								{relatedPosts.map((p) => (
									<li>
										<a href={`/blog/${p.id}/`}>{p.data.title}</a>
									</li>
								))}
							</ul>
						</aside>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
