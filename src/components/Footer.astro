---
import { SITE_TITLE } from '../consts';
const today = new Date();
---

<footer>
	<nav class="foot-links" aria-label="footer">
		<a href="/">홈</a>
		<a href="/blog">전체 글</a>
		<a href="/category">카테고리</a>
		<a href="/about">소개</a>
	</nav>
	<p class="disclosure">
		본 사이트는 쿠팡 파트너스·네이버 쇼핑파트너스 등 제휴 마케팅의 일환으로
		이를 통해 일정액의 수수료를 제공받을 수 있습니다.
	</p>
	<p class="copy">&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.</p>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.foot-links {
		display: flex;
		justify-content: center;
		gap: 1.2em;
		margin-bottom: 1em;
	}
	.foot-links a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-size: 0.9rem;
	}
	.foot-links a:hover {
		color: rgb(var(--accent));
	}
	.disclosure {
		font-size: 0.8rem;
		max-width: 640px;
		margin: 0 auto 0.8em auto;
		line-height: 1.5;
	}
	.copy {
		font-size: 0.85rem;
		margin: 0;
	}
</style>
